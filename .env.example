# Lark Webhook URL（必填）
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/your-hook-id

# OpenAI 兼容 API（必填，用于筛选/翻译/摘要）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 新模型（如 Azure GPT-5.x）使用 max_completion_tokens 而非 max_tokens
# 通常会根据模型名/Azure 地址自动识别，也可手动开启：
# OPENAI_USE_MAX_COMPLETION_TOKENS=true

# NewsAPI（可选，免费 500 次/天）
NEWSAPI_KEY=your-newsapi-key-here
